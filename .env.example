# microgpt-workbench Configuration

# Web server port
MICROGPT_PORT=8080

# Database path (SQLite)
MICROGPT_DB_PATH=./data/microgpt.db

# Service log directory
MICROGPT_LOG_DIR=./logs/

# MLflow tracking URI (HTTP server URI — single value drives writers AND readers)
# Default: http://127.0.0.1:5000 (the supervisor starts an MLflow server at this address)
MICROGPT_MLFLOW_URI=http://127.0.0.1:5000

# Storage backend (local or s3)
MICROGPT_STORAGE_BACKEND=local

# Device override for training (empty = auto-detect; "cpu", "cuda:0", "mps")
MICROGPT_DEVICE=