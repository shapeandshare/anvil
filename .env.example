# anvil Configuration

# Web server port
ANVIL_PORT=8080

# Database path (SQLite)
ANVIL_STATE_DB_PATH=./data/anvil-state.db

# Service log directory
ANVIL_LOG_DIR=./logs/

# MLflow tracking URI (HTTP server URI — single value drives writers AND readers)
# Default: http://127.0.0.1:5001 (the supervisor starts an MLflow server at this address)
# When accessing the web UI from another machine on your LAN, set this to the
# server's LAN IP so MLflow links work from remote browsers. For example:
#   ANVIL_MLFLOW_URI=http://192.168.1.50:5001
# If unset, the supervisor auto-detects the LAN IP on startup and uses it for
# browser-facing links (server still binds to 0.0.0.0 for LAN access).
# Port 5000 is avoided on macOS Sequoia+ where ControlCenter claims it.
ANVIL_MLFLOW_URI=http://127.0.0.1:5001

# Disable the locally-managed MLflow server process.
# Set to "true" when connecting to a hosted/remote MLflow service via
# ANVIL_MLFLOW_URI (e.g. Databricks, a shared server on your network).
# When false or unset, anvil spawns a local mlflow server subprocess.
# ANVIL_MLFLOW_DISABLE_LOCAL=false

# Storage backend (local or s3)
ANVIL_STORAGE_BACKEND=local

# Device override for training (empty = auto-detect; "cpu", "cuda:0", "mps")
ANVIL_DEVICE=

# Database auto-migration: set to "false" to require explicit CLI commands
# (default: "true" — auto-migrates on startup)
# ANVIL_DB_AUTO_MIGRATE=true