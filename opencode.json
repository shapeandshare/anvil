{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "vault": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bitbonsai/mcpvault@0.11.0",
        "docs/vault"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "python": {
      "command": [
        "npx",
        "-y",
        "--package",
        "pyright",
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    }
  }
}