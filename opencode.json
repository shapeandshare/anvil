{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "vault": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bitbonsai/mcpvault@0.11.0",
        "docs/vault"
      ],
      "enabled": true
    },
    "sonarcloud": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--init",
        "--pull=always",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_PROJECT_KEY",
        "mcp/sonarqube"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "python": {
      "command": [
        "npx",
        "-y",
        "--package",
        "pyright",
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    }
  }
}